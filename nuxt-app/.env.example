JWT_SECRET=change-me-to-a-random-string-in-production

# AI 配置：mock / openai / deepseek / custom
AI_PROVIDER=mock
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=
AI_MAX_TOKENS=2048
PHOTO_BACKFLOW_TOKEN=change-this-to-a-long-random-token
# Optional Ubuntu original-image HTTP service, reachable from the ECS container.
# ECS proxies the bytes after applying its own user/ACL checks.
PHOTO_ORIGINALS_BASE_URL=http://local.localhost:7080
PHOTO_ORIGINALS_TOKEN=change-this-to-a-long-random-token
