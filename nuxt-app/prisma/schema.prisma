// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  username      String   @unique
  password      String
  name          String
  role          String   @default("admin")
  groups        String?
  status        String   @default("active")
  aiAccess      Boolean  @default(false)
  aiAccessLevel String   @default("none")
  lastLoginAt   DateTime?
  tokenVersion  Int      @default(0)
  twoFactorEnabled       Boolean  @default(false)
  twoFactorSecret        String?
  twoFactorPendingSecret String?
  twoFactorRecoveryCodes String?
  uploadQuotaMb Int      @default(500)
  usedQuotaMb   Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  authSessions  AuthSession[]
}

model AuthSession {
  id         Int       @id @default(autoincrement())
  userId     Int
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, revokedAt, expiresAt])
}

model AiConversation {
  id        String      @id
  userId    Int
  title     String?
  archivedAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @default(now()) @updatedAt
  messages  AiMessage[]
  @@index([userId, updatedAt])
  @@index([userId, archivedAt, updatedAt])
}

model AiMessage {
  id             Int            @id @default(autoincrement())
  conversationId String
  role           String
  content        String
  createdAt      DateTime       @default(now())
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  @@index([conversationId, createdAt])
}

model Article {
  id          Int       @id @default(autoincrement())
  title       String
  slug        String    @unique
  content     String
  description String?
  coverImage  String?
  status      String    @default("draft")
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tags        Tag[]
}

model Tag {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  articles Article[]
}

model Photo {
  id                   Int      @id @default(autoincrement())
  title                String
  description          String?
  filename             String   @unique
  originalUrl          String
  thumbnailUrl         String?
  mediumUrl            String?
  width                Int?
  height               Int?
  orientation          Int?
  fileSize             Int?
  mimeType             String?
  location             String?
  gpsLatitude          Float?
  gpsLongitude         Float?
  cameraMake           String?
  cameraModel          String?
  lens                 String?
  iso                  Int?
  focalLength          Float?
  keywords             String?
  takenAt              DateTime?
  status               String   @default("published")  // published / hidden / archived
  originalPath         String?
  thumbPath            String?
  ecsThumbPath         String?
  visibility           String   @default("private")    // public / friends / private
  visibleTo            String?
  reviewStatus         String   @default("pending")    // pending / approved / rejected
  reviewNote           String?
  reviewedBy           Int?
  reviewedAt           DateTime?
  uploadedBy           Int?
  storageLocation      String   @default("local")      // 保留兼容，后续用 ecsSyncPolicy
  syncStatus           String   @default("pending")
  ecsSyncPolicy        String   @default("local_only") // synced / local_only / pending / syncing
  syncedAt             DateTime?
  syncError            String?
  checksum             String?
  thumbnailStatus      String   @default("ready") // pending / processing / ready / failed
  thumbnailError       String?
  thumbnailAttempts    Int      @default(0)
  thumbnailProcessedAt DateTime?
  archivedAt           DateTime?
  allowOriginalDownload Boolean @default(false)
  suggestedTags        String?
  suggestedLocation    String?
  suggestedDescription String?
  analysisStatus       String   @default("none")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  albums               AlbumPhoto[]
  tags                 PhotoTag[]
  @@index([visibility, status, reviewStatus, createdAt])
  @@index([takenAt])
  @@index([uploadedBy, visibility])
  @@index([thumbnailStatus, createdAt])
}

model Album {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  coverUrl    String?
  visibility  String   @default("public")
  visibleTo   String?
  reviewStatus String  @default("approved")
  createdAt   DateTime @default(now())
  photos      AlbumPhoto[]
  @@index([visibility, createdAt])
}

model AlbumPhoto {
  id       Int @id @default(autoincrement())
  photo    Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)
  photoId  Int
  album    Album @relation(fields: [albumId], references: [id], onDelete: Cascade)
  albumId  Int
  order    Int @default(0)
  @@unique([photoId, albumId])
  @@index([albumId, order])
}

model PhotoTag {
  id      Int   @id @default(autoincrement())
  photo   Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)
  photoId Int
  name    String
  @@unique([photoId, name])
  @@index([name])
}

model Portfolio {
  id           Int      @id @default(autoincrement())
  title        String
  slug         String   @unique
  description  String?
  content      String?
  coverImage   String?
  images       String?
  link         String?
  tags         String?
  category     String?
  featured     Boolean  @default(false)
  order        Int      @default(0)
  status       String   @default("draft")
  reviewStatus String   @default("approved")
  createdBy    String   @default("owner")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AuditLog {
  id           Int      @id @default(autoincrement())
  userId       Int?
  action       String
  resourceType String
  resourceId   String?
  beforeJson   String?
  afterJson    String?
  accessSource String?
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())
}

model HermesSkill {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  category    String?
  description String?
  path        String
  author      String?               // frontmatter author
  project     String?               // frontmatter project (e.g. personal-website)
  status      String   @default("new")
  riskLevel   String   @default("low")
  usageCount  Int      @default(0)
  lastUsedAt  DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tags        HermesSkillTag[]
}

model HermesSkillTag {
  id        Int      @id @default(autoincrement())
  skillName String
  tag       String                  // tag label, e.g. "优质", "项目专用", or any custom text
  tagType   String   @default("custom") // preset / custom
  createdAt DateTime @default(now())
  skill     HermesSkill @relation(fields: [skillName], references: [name], onDelete: Cascade)
  @@unique([skillName, tag])
  @@index([tag])
}

model Job {
  id        Int      @id @default(autoincrement())
  type      String
  status    String   @default("pending")
  payload   String?
  result    String?
  error     String?
  attempts  Int      @default(0)
  startedAt DateTime?
  finishedAt DateTime?
  availableAt DateTime?
  createdBy Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContentCandidate {
  id                  Int      @id @default(autoincrement())
  title               String
  slug                String?
  content             String
  description         String?
  contentType         String   @default("blog")
  source              String   @default("manual")
  status              String   @default("draft")
  tagsJson            String?
  sourceRef           String?
  suggestedVisibility String   @default("private")
  riskLevel           String   @default("low")
  createdBy           Int?
  reviewedBy          Int?
  reviewNote          String?
  publishedType       String?
  publishedId         Int?
  version             Int      @default(1)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  revisions           ContentRevision[]
  publications        ContentPublication[]
}

model ContentRevision {
  id           Int      @id @default(autoincrement())
  candidateId  Int
  version      Int
  title        String
  slug         String?
  content      String
  description  String?
  tagsJson     String?
  metadataJson String?
  createdBy    Int?
  createdAt    DateTime @default(now())
  candidate    ContentCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  @@unique([candidateId, version])
}

model ContentPublication {
  id           Int      @id @default(autoincrement())
  candidateId  Int
  targetType   String
  targetId     Int
  status       String   @default("draft")
  publishedBy  Int?
  publishedAt  DateTime?
  unpublishedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  candidate    ContentCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  @@unique([candidateId, targetType])
}
