# === 敏感内容 ===
.env
.env.*
!.env.example

# === 照片和媒体文件 ===
photos/
thumbnails/
uploads/
public/uploads/
nuxt-app/public/uploads/
originals/
# These are source directories, not uploaded media.
!nuxt-app/pages/admin/photos/
!nuxt-app/pages/admin/photos/index.vue
!nuxt-app/server/api/photos/
!nuxt-app/server/api/photos/index.get.ts
!nuxt-app/server/api/photos/[id].get.ts
!nuxt-app/server/api/photos/[id].patch.ts

# === 数据库和运行时 ===
*.db
*.db-journal
*.sqlite
*.sqlite3
*.dump
*.backup

# === 备份和日志 ===
backups/
logs/
*.log
*.tar.gz
*.tar
releases/

# === 用户上传与运行时媒体（任意目录） ===
*.jpg
*.jpeg
*.png
*.webp
*.gif
*.heic
*.raw
*.dng
*.mov
*.mp4

# === Runtime article/content-pipeline data; mounted volumes, never tracked ===
content/inbox/
content/raw/
content/generated/
content/drafts/
data/blog-md/
data/content-pipeline/

# === Hermes 运行时数据 ===
.hermes/

# === Nuxt/Node 产物 ===
nuxt-app/.output
nuxt-app/.data
nuxt-app/.nuxt
nuxt-app/.nitro
nuxt-app/.cache
nuxt-app/dist
nuxt-app/node_modules

# === Prisma 生成 ===
nuxt-app/generated/prisma

# === IDE 和系统文件 ===
.DS_Store
.fleet
.idea
.vscode

# === 临时文件 ===
*.tmp
*.temp
test-export/
